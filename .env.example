# Runtime storage
COMPANY_DISCOVERY_HOME=.company-discovery

# External company discovery
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_RESULTS_PER_QUERY=25

# Structured query planning and company evaluation
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5-mini
LLM_RESPONSE_FORMAT=auto
LLM_MAX_TOKENS=4096

# Targeted official-site enrichment
ENRICHMENT_FRESHNESS_DAYS=180
ENRICHMENT_WEBSITE_TIMEOUT_SECONDS=20
ENRICHMENT_MAX_PAGES=4
ENRICHMENT_FALLBACK_RESULTS=5
