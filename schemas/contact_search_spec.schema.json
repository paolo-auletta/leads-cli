{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contact_search_spec.schema.json",
  "title": "Contact Search Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "company_source", "roles"],
  "properties": {
    "version": {"const": 1},
    "company_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enrichment_run_id"],
      "properties": {
        "enrichment_run_id": {"type": "string", "minLength": 1},
        "bucket": {"enum": ["ready", "review", "all"], "default": "ready"},
        "domains": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "default": []
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "labels"],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 2,
            "maxLength": 64,
            "pattern": "^[A-Za-z][A-Za-z0-9 _-]{1,63}$"
          },
          "labels": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {"type": "string", "minLength": 2}
          },
          "max_per_company": {"type": "integer", "minimum": 1, "maximum": 10, "default": 1}
        }
      }
    },
    "company_limit": {"type": ["integer", "null"], "minimum": 1, "maximum": 1000},
    "contact_limit": {"type": ["integer", "null"], "minimum": 1, "maximum": 10000},
    "current_only": {"type": "boolean", "default": true},
    "require_role_match": {"type": "boolean", "default": true},
    "memory_freshness_days": {"type": "integer", "minimum": 1, "maximum": 365, "default": 30}
  }
}
