{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.company-discovery/schemas/company_search_spec.schema.json",
  "title": "CompanySearchSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "count"],
  "oneOf": [
    {"required": ["vertical"], "not": {"required": ["verticals"]}},
    {"required": ["verticals"], "not": {"required": ["vertical"]}}
  ],
  "$defs": {
    "vertical": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label"],
      "properties": {
        "key": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9_-]*$"},
        "label": {"type": "string", "minLength": 1},
        "search_terms": {"type": "array", "items": {"type": "string"}, "default": []},
        "exclude_terms": {"type": "array", "items": {"type": "string"}, "default": []},
        "mode": {"enum": ["known", "exploratory"]},
        "seed_terms": {"type": "array", "items": {"type": "string"}, "default": []},
        "anti_terms": {"type": "array", "items": {"type": "string"}, "default": []}
      },
      "allOf": [
        {"not": {"required": ["search_terms", "seed_terms"]}},
        {"not": {"required": ["exclude_terms", "anti_terms"]}}
      ]
    }
  },
  "properties": {
    "version": {"const": 1},
    "count": {"type": "integer", "minimum": 1, "maximum": 1000},
    "vertical": {"$ref": "#/$defs/vertical"},
    "verticals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/vertical"}
    },
    "geography": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "country": {"type": "string", "minLength": 2, "maxLength": 2, "default": "US"},
        "states": {"type": "array", "items": {"type": "string"}, "default": []}
      },
      "default": {"country": "US", "states": []}
    },
    "company_size": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "employee_min": {"type": ["integer", "null"], "minimum": 1},
        "employee_max": {"type": ["integer", "null"], "minimum": 1}
      },
      "default": {}
    },
    "include": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": {"type": "array", "items": {"type": "string"}, "default": []},
        "subtypes": {"type": "array", "items": {"type": "string"}, "default": []}
      },
      "default": {}
    },
    "exclude": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": {"type": "array", "items": {"type": "string"}, "default": []},
        "ownership_types": {"type": "array", "items": {"type": "string"}, "default": []},
        "company_patterns": {"type": "array", "items": {"type": "string"}, "default": []},
        "structured": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ownership_signals": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "enum": [
                  "family_owned",
                  "franchise",
                  "parent",
                  "subsidiary",
                  "division",
                  "acquired"
                ]
              },
              "default": []
            }
          },
          "default": {}
        }
      },
      "default": {}
    },
    "novelty_mode": {
      "enum": ["unused_memory", "only_new", "full_memory"],
      "default": "unused_memory"
    },
    "reserve_ratio": {"type": "number", "minimum": 0, "maximum": 2, "default": 0.5},
    "balance_mode": {"enum": ["soft", "strict", "none"], "default": "soft"},
    "external_search": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exa_searches": {"type": "integer", "minimum": 1, "maximum": 20, "default": 8},
        "results_per_search": {"type": "integer", "minimum": 1, "maximum": 100, "default": 5}
      },
      "default": {"exa_searches": 8, "results_per_search": 5}
    }
  }
}
